
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Regras para a coleção roles_admin
    match /roles_admin/{userId} {
      // Cadastro de loja cria o próprio registro de admin. Login anônimo
      // (clientes do cardápio) não pode se autopromover a admin.
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow get, list, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false; // Por segurança, não permite deletar admin via app
    }

    // Regras para Categorias e Itens
    // Adicionamos a lógica de ownerId para isolar os dados
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
      // Cliente (anônimo) só pode BAIXAR o estoque ao fazer pedido — nunca
      // aumentar nem deixar negativo. Reposição/estorno é só do dono (admin).
      allow update: if (isAdmin() && resource.data.ownerId == request.auth.uid) ||
        (isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity'])
          && request.resource.data.stockQuantity is number
          && request.resource.data.stockQuantity >= 0
          && resource.data.stockQuantity is number
          && request.resource.data.stockQuantity < resource.data.stockQuantity);
    }

    match /addons/{addonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /addonCategories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /customers/{userId} {
      allow get, update, create: if isSignedIn() && request.auth.uid == userId;
      allow list, delete: if false;
    }

    match /orders/{orderId} {
      // Cliente lê os próprios pedidos via customerUid (uid anônimo gravado
      // na criação); dono lê os pedidos da loja. A query do cliente PRECISA
      // filtrar por customerUid == uid (my-orders/banner já fazem isso).
      allow get, list: if isSignedIn() && (
        resource.data.customerUid == request.auth.uid ||
        (isAdmin() && resource.data.ownerId == request.auth.uid)
      );
      allow update: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && (
        request.resource.data.customerUid == request.auth.uid ||
        (isAdmin() && request.resource.data.ownerId == request.auth.uid)
      );
      allow delete: if false;
    }

    // Encomendas (modalidade confeitaria): mesmo modelo de orders, em coleção
    // PRÓPRIA (não filtrada pela janela do caixa — registra com caixa fechado).
    // Cliente (anônimo) cria a própria encomenda (customerUid == uid); o dono
    // lê/atualiza as encomendas da loja (ownerId == uid).
    match /encomendas/{encomendaId} {
      allow get, list: if isSignedIn() && (
        resource.data.customerUid == request.auth.uid ||
        (isAdmin() && resource.data.ownerId == request.auth.uid)
      );
      allow create: if isSignedIn() && (
        request.resource.data.customerUid == request.auth.uid ||
        (isAdmin() && request.resource.data.ownerId == request.auth.uid)
      );
      allow update: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    match /cash_registers/{registerId} {
      // Movimento financeiro é só do dono. O cardápio do cliente usa
      // store_profiles.isCaixaAberto para saber se o caixa está aberto.
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /cash_transactions/{transactionId} {
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /clientes/{clienteId} {
      // Leitura exige login (o anônimo do cardápio serve): o my-orders busca
      // o cliente por telefone para a Conta da Casa. Fechar mais que isso
      // exige mover essas consultas para API routes com Admin SDK.
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );

      match /credit_transactions/{transactionId} {
        // Extrato visível para usuário logado (cliente vê o próprio fiado no
        // my-orders); lançamentos só pelo dono da loja do cliente.
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin()
          && get(/databases/$(database)/documents/clientes/$(clienteId)).data.ownerId == request.auth.uid;
      }
    }

    match /store_profiles/{profileId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && request.auth.uid == profileId;
    }

    match /active_sessions/{sessionId} {
      // Ping de presença do cardápio: o cliente pode ainda não estar logado,
      // então a escrita é aberta mas restrita ao formato do ping.
      allow create, update: if request.resource.data.keys().hasOnly(['storeId', 'lastActive']);
      allow delete: if true;
      allow get, list: if isAdmin();
    }

    match /promotions/{promoId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /campaigns/{campaignId} {
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create: if isAdmin() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() && resource.data.ownerId == request.auth.uid;
    }

    match /broadcast_lists/{listId} {
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create: if isAdmin() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() && resource.data.ownerId == request.auth.uid;
    }

    // Disparo agendado/segundo plano. O dono cria e lê (progresso em realtime) e
    // pode cancelar (update/delete). Os writes de envio (cursor/sent/failed/...)
    // são feitos pelo servidor via Admin SDK, que ignora estas regras.
    match /scheduled_campaigns/{campaignId} {
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create: if isAdmin() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() && resource.data.ownerId == request.auth.uid;
    }

    match /whatsapp_messages/{messageId} {
      allow get, list: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create: if isAdmin()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.empresaId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
