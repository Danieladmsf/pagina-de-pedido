
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Regras para a coleção roles_admin
    match /roles_admin/{userId} {
      // Qualquer um pode criar seu próprio registro de admin ao se cadastrar
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow get, list, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false; // Por segurança, não permite deletar admin via app
    }

    // Regras para Categorias e Itens
    // Adicionamos a lógica de ownerId para isolar os dados
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /addons/{addonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin() && (
        (request.method == 'create' && request.resource.data.ownerId == request.auth.uid) ||
        (resource.data.ownerId == request.auth.uid)
      );
    }

    match /customers/{userId} {
      allow get, update, create: if isSignedIn() && request.auth.uid == userId;
      allow list, delete: if false;
    }

    match /cashSessions/{sessionId} {
      allow list, get: if isAdmin();
      allow create: if isAdmin() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (
        resource.data.customerIdentifier == request.auth.uid ||
        (isAdmin() && resource.data.ownerId == request.auth.uid)
      );
      allow list: if isSignedIn();
      allow update: if isAdmin() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if false;
    }
  }
}
