/**
 * PRONTO PEDIDO - FIRESTORE SECURITY RULES
 *
 * Core Philosophy:
 * This ruleset implements a robust, role-based and ownership-based security model. 
 * The application distinguishes between public menu content (managed by admins) and private 
 * customer transaction data (managed by users).
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /optionGroups/{menuItemOptionGroupId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /optionGroups/{optionGroupId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /optionItems/{optionItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Allow get if admin or the owner
      allow get: if isAdmin() || (resource != null && resource.data.customerIdentifier == request.auth.uid);
      
      // Allow list if admin (all) OR if filtered by customerIdentifier (owner)
      allow list: if isAdmin() || (isSignedIn() && request.query.filters.customerIdentifier == request.auth.uid);
      
      allow create: if isSignedIn() && request.resource.data.customerIdentifier == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.customerIdentifier == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.customerIdentifier == request.auth.uid);

      match /items/{orderItemId} {
        allow get, list: if isAdmin() || (resource != null && resource.data.customerIdentifier == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.customerIdentifier == request.auth.uid;
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.customerIdentifier == request.auth.uid);

        match /options/{orderItemOptionId} {
          allow get, list: if isAdmin() || (resource != null && resource.data.customerIdentifier == request.auth.uid);
          allow create: if isSignedIn() && request.resource.data.customerIdentifier == request.auth.uid;
          allow update, delete: if isAdmin() || (isSignedIn() && resource.data.customerIdentifier == request.auth.uid);
        }
      }
    }
  }
}